# Thresholds
MIN_EVENTS_FOR_REC=3
REC_COOLDOWN=120
INSIGHT_COOLDOWN=10

# Auth
JWT_SECRET=change-this-in-production
RESEND_API_KEY=re_bkmn5tFC_3CB4cNoQ9keuDSRsdaJxPai2
